            },
            "url": {
              "raw": "{{baseUrl}}/auth/send-otp",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "send-otp"
              ]
            }
          }
        },
        {
          "name": "Verify Admin OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.status && json.data && json.data.token) {",
                  "  pm.collectionVariables.set('adminToken', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
