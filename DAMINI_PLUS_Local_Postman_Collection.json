              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "app",
                "auth",
                "send-otp"
              ]
            }
          }
        },
        {
          "name": "Verify Student OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.status && json.data && json.data.token) {",
                  "  pm.collectionVariables.set('studentToken', json.data.token);",
                  "  if (json.data.user && json.data.user.id) pm.collectionVariables.set('userId', json.data.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
