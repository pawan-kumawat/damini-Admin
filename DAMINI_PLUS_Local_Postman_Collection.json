    {
      "name": "Student App Auth",
      "item": [
        {
          "name": "Send Student OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.status && json.data && json.data.devOtp) {",
                  "  pm.collectionVariables.set('studentOtp', json.data.devOtp);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
