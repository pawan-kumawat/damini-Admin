            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.status && json.data && json.data.token) {",
                  "  pm.collectionVariables.set('adminToken', json.data.token);",
