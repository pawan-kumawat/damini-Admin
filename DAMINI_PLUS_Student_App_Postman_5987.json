{
  "info": {
    "_postman_id": "daminiplus-student-app-5987",
    "name": "DAMINI+ Student App APIs - Local 5987",
    "description": "Only student app APIs for DAMINI+ local backend. Base URL: http://localhost:5987/api/v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5987/api/v1" },
    { "key": "studentEmail", "value": "student@test.com" },
    { "key": "studentName", "value": "Test Student" },
    { "key": "studentOtp", "value": "" },
    { "key": "studentToken", "value": "" },
    { "key": "languageId", "value": "" },
    { "key": "boardId", "value": "" },
    { "key": "classId", "value": "" },
    { "key": "subjectId", "value": "" },
    { "key": "topicId", "value": "" },
    { "key": "questionId", "value": "" },
    { "key": "subscriptionId", "value": "" },
    { "key": "paymentId", "value": "postman_test_payment" },
    { "key": "submissionId", "value": "" }
  ],
  "item": [
    {
      "name": "01 Auth",
      "item": [
        {
          "name": "Send Student OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.status && json.data && json.data.devOtp) {",
                  "  pm.collectionVariables.set('studentOtp', json.data.devOtp);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{studentEmail}}\",\n  \"name\": \"{{studentName}}\"\n}"
            },
            "url": "{{baseUrl}}/app/auth/send-otp"
          }
        },
        {
          "name": "Verify Student OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.status && json.data) {",
                  "  if (json.data.token) pm.collectionVariables.set('studentToken', json.data.token);",
                  "  if (json.data.user && json.data.user.languageId) pm.collectionVariables.set('languageId', json.data.user.languageId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{studentEmail}}\",\n  \"otp\": \"{{studentOtp}}\",\n  \"name\": \"{{studentName}}\"\n}"
            },
            "url": "{{baseUrl}}/app/auth/verify-otp"
          }
        }
      ]
    },
